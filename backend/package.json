{
  "name": "stock-viz-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "drizzle-kit introspect && sed -i \"s|from \\\"./schema\\\"|from \\\"./schema.js\\\"|g\" src/db/relations.ts && tsc",
    "start": "node dist/index.js",
    "check": "npm run lint && npm run format -- --check",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist src/db/schema.ts src/db/relations.ts src/db/meta src/db/*.sql",
    "db:introspect": "drizzle-kit introspect"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
